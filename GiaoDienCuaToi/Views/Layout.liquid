<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Website của tôi</title>

    {% style src:"~/GiaoDienCuaToi/css/style.css" %}
    
    <!-- Google Fonts: Inter & Playfair Display -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet">
    
    <!-- Google Material Symbols -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    {% resources type: "Meta" %}
    {% resources type: "HeadLink" %}
    {% resources type: "Stylesheet" %}
    {% resources type: "HeadScript" %}

    
    {% script src:"~/GiaoDienCuaToi/js/main.js", at:"Foot" %}
</head>
<body style="margin: 0; padding: 0;">
    <!-- Thêm một chút CSS để Menu động của Orchard Core hiển thị ngang hàng đẹp mắt -->
    <style>
        .nav-menu ul { display: flex; list-style: none; margin: 0; padding: 0; gap: 20px; align-items: center; }
        .nav-menu li { margin: 0; padding: 0; }
        .nav-menu a { text-decoration: none; color: inherit; }
    </style>

    <header class="header">
        <div class="container">
            <a href="{{ '~/' | href }}" class="logo">ARCHIVE</a>
            
            <nav class="nav-menu">
                <!-- Vòng lặp thủ công siêu cấp vô địch để lấy dữ liệu Menu -->
                {% assign mymenu = Content.ContentItemId["menu00000000000000chinhmoi"] %}
                {% if mymenu != null %}
                    {% for item in mymenu.Content.MenuPart.MenuItems %}
                        <a href="{{ item.LinkMenuItemPart.Url | href }}">{{ item.LinkMenuItemPart.Name }}</a>
                    {% endfor %}
                {% else %}
                    <a href="#">Lỗi: Không tìm thấy Menu</a>
                {% endif %}
            </nav>
            
            <div class="header-actions">
                <button class="icon-btn"><span class="material-symbols-outlined">language</span></button>
                <button class="icon-btn"><span class="material-symbols-outlined">search</span></button>
            </div>
        </div>
    </header>

    <main>
        {% render_section "Content", required: false %}
    </main>

    <footer>
        {% render_section "Footer", required: false %}
    </footer>



    {% resources type: "FootScript" %}
</body>
</html>